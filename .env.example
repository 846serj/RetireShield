# Copy to .env.local and fill in. The app RUNS WITHOUT these (leads log to console),
# but set Supabase to actually persist leads.

# Copy to .env.local and fill in. The free-Score flow runs with NONE of these.
# Auth + billing (Phase 3-6) need the Supabase + Stripe values.

NEXT_PUBLIC_BASE_URL=https://retireguard.onrender.com

# --- Supabase (auth + data) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Phase 4) — use TEST keys until lawyer sign-off (Phase 6) ---
STRIPE_SECRET_KEY=
STRIPE_PRICE_ANNUAL=
STRIPE_PRICE_MONTHLY=
STRIPE_WEBHOOK_SECRET=

# --- Email / ESP (Phase 7) ---
ESP_API_KEY=

# --- Analytics (Phase 8) ---
NEXT_PUBLIC_POSTHOG_KEY=
